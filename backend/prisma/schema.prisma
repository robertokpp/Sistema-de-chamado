generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  technical
  client
}

enum Status {
  open
  inProgress
  close
}

model Client {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role      @default(client)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  calls     Calls[]

  @@map("client")
}

model Technical {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  role      Role     @default(technical)
  calls     Calls[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("technical")
}

model Calls {
  id          String    @id @default(uuid())
  title       String
  service     String
  description String
  value       Float
  status Status @default(open)
  technicalId String?
  technical   Technical? @relation(fields: [technicalId], references: [id])
  clientId    String
  client      Client      @relation(fields: [clientId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("calls")
}
